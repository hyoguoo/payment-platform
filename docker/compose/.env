# ============================================================
# Benchmark 환경 기본값 — Single Source of Truth
# docker compose가 자동으로 로드합니다.
# run-benchmark.sh는 케이스별 값만 오버라이드합니다.
# ============================================================

# ===== 앱 전략 =====
ASYNC_STRATEGY=sync
VIRTUAL_THREADS_ENABLED=false   # 미사용 (benchmark 프로파일에서 Tomcat은 PT 고정)
CHANNEL_VIRTUAL_THREADS=true    # Worker VT 여부 (Tomcat과 독립 제어)
OUTBOX_BATCH_SIZE=50
SCHEDULER_PARALLEL_ENABLED=true # OutboxWorker 폴백 병렬 처리 여부

# ===== Toss API 딜레이 시뮬레이션 =====
# 저지연(낙관적): MIN=100  MAX=300
# 고지연(현실적): MIN=800  MAX=1500
TOSS_MIN_DELAY_MILLIS=100
TOSS_MAX_DELAY_MILLIS=300
